<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="eo_v_stake">Stake</variable>
    <variable id="eo_v_istake">Initial Stake</variable>
    <variable id="eo_v_tp">Target Profit</variable>
    <variable id="eo_v_sl">Stop Loss</variable>
    <variable id="eo_v_mf">Martingale Factor</variable>
    <variable id="eo_v_um">Use Martingale</variable>
    <variable id="eo_v_ml">Max Losses</variable>
    <variable id="eo_v_lc">Loss Counter</variable>
    <variable id="eo_v_ld">Last Digit</variable>
    <variable id="eo_v_ed">Entry Digit</variable>
    <variable id="eo_v_ep">Entry Point</variable>
    <variable id="eo_v_txt">text</variable>
  </variables>

  <!-- ── TRADE DEFINITION ── -->
  <block type="trade_definition" id="eo_td" deletable="false" x="0" y="60">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="eo_mkt" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ10V</field>
        <next>
          <block type="trade_definition_tradetype" id="eo_tt" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="eo_ct" deletable="false" movable="false">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="eo_ci" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="eo_rtm" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="eo_roe" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <!-- ── INITIALIZATION ── -->
    <statement name="INITIALIZATION">
      <block type="notify" id="eo_init_n">
        <field name="NOTIFICATION_TYPE">success</field>
        <field name="NOTIFICATION_SOUND">silent</field>
        <value name="MESSAGE">
          <shadow type="text" id="eo_init_s"><field name="TEXT">abc</field></shadow>
          <block type="text" id="eo_init_t">
            <field name="TEXT">Even Odd Manual Trading Bot — Trader Charloh💵💷  ·  Waiting for Entry Digit…</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="eo_i_stk">
            <field name="VAR" id="eo_v_stake">Stake</field>
            <value name="VALUE"><block type="math_number" id="eo_n_stk"><field name="NUM">1</field></block></value>
            <next>
              <block type="variables_set" id="eo_i_istk">
                <field name="VAR" id="eo_v_istake">Initial Stake</field>
                <value name="VALUE"><block type="math_number" id="eo_n_istk"><field name="NUM">1</field></block></value>
                <next>
                  <block type="variables_set" id="eo_i_tp">
                    <field name="VAR" id="eo_v_tp">Target Profit</field>
                    <value name="VALUE"><block type="math_number" id="eo_n_tp"><field name="NUM">10</field></block></value>
                    <next>
                      <block type="variables_set" id="eo_i_sl">
                        <field name="VAR" id="eo_v_sl">Stop Loss</field>
                        <value name="VALUE"><block type="math_number" id="eo_n_sl"><field name="NUM">5</field></block></value>
                        <next>
                          <block type="variables_set" id="eo_i_mf">
                            <field name="VAR" id="eo_v_mf">Martingale Factor</field>
                            <value name="VALUE"><block type="math_number" id="eo_n_mf"><field name="NUM">2</field></block></value>
                            <next>
                              <block type="variables_set" id="eo_i_um">
                                <field name="VAR" id="eo_v_um">Use Martingale</field>
                                <value name="VALUE"><block type="logic_boolean" id="eo_b_um"><field name="BOOL">TRUE</field></block></value>
                                <next>
                                  <block type="variables_set" id="eo_i_ml">
                                    <field name="VAR" id="eo_v_ml">Max Losses</field>
                                    <value name="VALUE"><block type="math_number" id="eo_n_ml"><field name="NUM">6</field></block></value>
                                    <next>
                                      <block type="variables_set" id="eo_i_lc">
                                        <field name="VAR" id="eo_v_lc">Loss Counter</field>
                                        <value name="VALUE"><block type="math_number" id="eo_n_lc"><field name="NUM">0</field></block></value>
                                        <next>
                                          <!-- Entry Digit — user-configurable. 0,2,4,6,8 → buys EVEN. 1,3,5,7,9 → buys ODD. -->
                                          <block type="variables_set" id="eo_i_ed">
                                            <field name="VAR" id="eo_v_ed">Entry Digit</field>
                                            <value name="VALUE"><block type="math_number" id="eo_n_ed"><field name="NUM">4</field></block></value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <!-- ── TRADE OPTIONS ── -->
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="eo_to">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION"><shadow type="math_number" id="eo_dur_s"><field name="NUM">1</field></shadow></value>
        <value name="AMOUNT">
          <shadow type="math_number" id="eo_amt_s"><field name="NUM">1</field></shadow>
          <block type="variables_get" id="eo_amt_g"><field name="VAR" id="eo_v_stake">Stake</field></block>
        </value>
      </block>
    </statement>
  </block>

  <!-- ── BEFORE PURCHASE: only buy when Last Digit == Entry Digit ── -->
  <block type="before_purchase" id="eo_bp" deletable="false" x="0" y="840">
    <statement name="BEFOREPURCHASE_STACK">
      <!-- Get last digit -->
      <block type="variables_set" id="eo_bp_ld">
        <field name="VAR" id="eo_v_ld">Last Digit</field>
        <value name="VALUE"><block type="last_digit" id="eo_ld_blk"></block></value>
        <next>
          <!-- IF Last Digit == Entry Digit → buy. Else → wait (no purchase, loops next tick) -->
          <block type="controls_if" id="eo_gate_if">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0">
              <block type="logic_compare" id="eo_gate_cmp">
                <field name="OP">EQ</field>
                <value name="A"><block type="variables_get" id="eo_gate_ld"><field name="VAR" id="eo_v_ld">Last Digit</field></block></value>
                <value name="B"><block type="variables_get" id="eo_gate_ed"><field name="VAR" id="eo_v_ed">Entry Digit</field></block></value>
              </block>
            </value>

            <!-- ENTRY HIT → choose direction by parity of Entry Digit -->
            <statement name="DO0">
              <block type="controls_if" id="eo_dir_if">
                <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                <value name="IF0">
                  <block type="logic_compare" id="eo_dir_cmp">
                    <field name="OP">EQ</field>
                    <value name="A">
                      <block type="math_modulo" id="eo_dir_mod">
                        <value name="DIVIDEND"><block type="variables_get" id="eo_dir_ed"><field name="VAR" id="eo_v_ed">Entry Digit</field></block></value>
                        <value name="DIVISOR"><block type="math_number" id="eo_dir_two"><field name="NUM">2</field></block></value>
                      </block>
                    </value>
                    <value name="B"><block type="math_number" id="eo_dir_zero"><field name="NUM">0</field></block></value>
                  </block>
                </value>

                <!-- EVEN -->
                <statement name="DO0">
                  <block type="variables_set" id="eo_ep_e">
                    <field name="VAR" id="eo_v_ep">Entry Point</field>
                    <value name="VALUE"><block type="text" id="eo_t_e"><field name="TEXT">EVEN</field></block></value>
                    <next>
                      <block type="text_join" id="eo_tj_e">
                        <field name="VARIABLE" id="eo_v_txt">text</field>
                        <statement name="STACK">
                          <block type="text_statement" id="eo_ts_e1"><value name="TEXT"><shadow type="text"><field name="TEXT">📍 Entry HIT — Digit </field></shadow></value>
                            <next><block type="text_statement" id="eo_ts_e2"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ld_ge"><field name="VAR" id="eo_v_ld">Last Digit</field></block></value>
                              <next><block type="text_statement" id="eo_ts_e3"><value name="TEXT"><shadow type="text"><field name="TEXT"> matches Entry </field></shadow></value>
                                <next><block type="text_statement" id="eo_ts_e4"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ed_ge"><field name="VAR" id="eo_v_ed">Entry Digit</field></block></value>
                                  <next><block type="text_statement" id="eo_ts_e5"><value name="TEXT"><shadow type="text"><field name="TEXT">. Buying EVEN ✅</field></shadow></value></block></next>
                                </block></next>
                              </block></next>
                            </block></next>
                          </block>
                        </statement>
                        <next>
                          <block type="notify" id="eo_n_e">
                            <field name="NOTIFICATION_TYPE">success</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_txt_ge"><field name="VAR" id="eo_v_txt">text</field></block></value>
                            <next><block type="purchase" id="eo_buy_e"><field name="PURCHASE_LIST">DIGITEVEN</field></block></next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </statement>

                <!-- ODD -->
                <statement name="ELSE">
                  <block type="variables_set" id="eo_ep_o">
                    <field name="VAR" id="eo_v_ep">Entry Point</field>
                    <value name="VALUE"><block type="text" id="eo_t_o"><field name="TEXT">ODD</field></block></value>
                    <next>
                      <block type="text_join" id="eo_tj_o">
                        <field name="VARIABLE" id="eo_v_txt">text</field>
                        <statement name="STACK">
                          <block type="text_statement" id="eo_ts_o1"><value name="TEXT"><shadow type="text"><field name="TEXT">📍 Entry HIT — Digit </field></shadow></value>
                            <next><block type="text_statement" id="eo_ts_o2"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ld_go"><field name="VAR" id="eo_v_ld">Last Digit</field></block></value>
                              <next><block type="text_statement" id="eo_ts_o3"><value name="TEXT"><shadow type="text"><field name="TEXT"> matches Entry </field></shadow></value>
                                <next><block type="text_statement" id="eo_ts_o4"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ed_go"><field name="VAR" id="eo_v_ed">Entry Digit</field></block></value>
                                  <next><block type="text_statement" id="eo_ts_o5"><value name="TEXT"><shadow type="text"><field name="TEXT">. Buying ODD ✅</field></shadow></value></block></next>
                                </block></next>
                              </block></next>
                            </block></next>
                          </block>
                        </statement>
                        <next>
                          <block type="notify" id="eo_n_o">
                            <field name="NOTIFICATION_TYPE">success</field>
                            <field name="NOTIFICATION_SOUND">silent</field>
                            <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_txt_go"><field name="VAR" id="eo_v_txt">text</field></block></value>
                            <next><block type="purchase" id="eo_buy_o"><field name="PURCHASE_LIST">DIGITODD</field></block></next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </statement>
              </block>
            </statement>

            <!-- NO ENTRY → log scan, no purchase (loop next tick) -->
            <statement name="ELSE">
              <block type="text_join" id="eo_tj_w">
                <field name="VARIABLE" id="eo_v_txt">text</field>
                <statement name="STACK">
                  <block type="text_statement" id="eo_ts_w1"><value name="TEXT"><shadow type="text"><field name="TEXT">🔍 Scanning… Last </field></shadow></value>
                    <next><block type="text_statement" id="eo_ts_w2"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ld_gw"><field name="VAR" id="eo_v_ld">Last Digit</field></block></value>
                      <next><block type="text_statement" id="eo_ts_w3"><value name="TEXT"><shadow type="text"><field name="TEXT"> ≠ Entry </field></shadow></value>
                        <next><block type="text_statement" id="eo_ts_w4"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ed_gw"><field name="VAR" id="eo_v_ed">Entry Digit</field></block></value>
                          <next><block type="text_statement" id="eo_ts_w5"><value name="TEXT"><shadow type="text"><field name="TEXT"> — waiting…</field></shadow></value></block></next>
                        </block></next>
                      </block></next>
                    </block></next>
                  </block>
                </statement>
                <next>
                  <block type="notify" id="eo_n_w">
                    <field name="NOTIFICATION_TYPE">warn</field>
                    <field name="NOTIFICATION_SOUND">silent</field>
                    <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_txt_gw"><field name="VAR" id="eo_v_txt">text</field></block></value>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- ── AFTER PURCHASE: TP / Win / Loss-with-Martingale / SL / MaxLoss ── -->
  <block type="after_purchase" id="eo_ap" x="886" y="60">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="eo_tp_chk">
        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
        <value name="IF0">
          <block type="logic_compare" id="eo_tp_cmp">
            <field name="OP">GTE</field>
            <value name="A"><block type="total_profit" id="eo_tp_val"></block></value>
            <value name="B"><block type="variables_get" id="eo_tp_g"><field name="VAR" id="eo_v_tp">Target Profit</field></block></value>
          </block>
        </value>
        <statement name="DO0">
          <block type="text_join" id="eo_tp_tj">
            <field name="VARIABLE" id="eo_v_txt">text</field>
            <statement name="STACK">
              <block type="text_statement" id="eo_tp_ts0"><value name="TEXT"><shadow type="text"><field name="TEXT">🎯 Target Profit hit! </field></shadow></value>
                <next><block type="text_statement" id="eo_tp_ts1"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="total_profit" id="eo_tp_pv"></block></value>
                  <next><block type="text_statement" id="eo_tp_ts2"><value name="TEXT"><shadow type="text"><field name="TEXT"> USD printed 💲💲 — bot stopped.</field></shadow></value></block></next>
                </block></next>
              </block>
            </statement>
            <next>
              <block type="notify" id="eo_tp_n">
                <field name="NOTIFICATION_TYPE">success</field>
                <field name="NOTIFICATION_SOUND">earned-money</field>
                <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_tp_tg"><field name="VAR" id="eo_v_txt">text</field></block></value>
              </block>
            </next>
          </block>
        </statement>

        <statement name="ELSE">
          <block type="controls_if" id="eo_win_chk">
            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
            <value name="IF0"><block type="contract_check_result" id="eo_cr"><field name="CHECK_RESULT">win</field></block></value>
            <statement name="DO0">
              <block type="variables_set" id="eo_w_stk">
                <field name="VAR" id="eo_v_stake">Stake</field>
                <value name="VALUE"><block type="variables_get" id="eo_w_is"><field name="VAR" id="eo_v_istake">Initial Stake</field></block></value>
                <next>
                  <block type="variables_set" id="eo_w_lc">
                    <field name="VAR" id="eo_v_lc">Loss Counter</field>
                    <value name="VALUE"><block type="math_number" id="eo_w_lc0"><field name="NUM">0</field></block></value>
                    <next><block type="trade_again" id="eo_ta_win"></block></next>
                  </block>
                </next>
              </block>
            </statement>

            <statement name="ELSE">
              <block type="math_change" id="eo_l_inc">
                <field name="VAR" id="eo_v_lc">Loss Counter</field>
                <value name="DELTA"><shadow type="math_number" id="eo_l_d"><field name="NUM">1</field></shadow></value>
                <next>
                  <block type="controls_if" id="eo_mg_chk">
                    <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                    <value name="IF0"><block type="variables_get" id="eo_um_g"><field name="VAR" id="eo_v_um">Use Martingale</field></block></value>
                    <statement name="DO0">
                      <block type="variables_set" id="eo_mg_s">
                        <field name="VAR" id="eo_v_stake">Stake</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="eo_mg_m">
                            <field name="OP">MULTIPLY</field>
                            <value name="A"><shadow type="math_number"><field name="NUM">1</field></shadow><block type="variables_get" id="eo_sk_g"><field name="VAR" id="eo_v_stake">Stake</field></block></value>
                            <value name="B"><shadow type="math_number"><field name="NUM">1</field></shadow><block type="variables_get" id="eo_mf_g"><field name="VAR" id="eo_v_mf">Martingale Factor</field></block></value>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <block type="variables_set" id="eo_no_mg">
                        <field name="VAR" id="eo_v_stake">Stake</field>
                        <value name="VALUE"><block type="variables_get" id="eo_is_g2"><field name="VAR" id="eo_v_istake">Initial Stake</field></block></value>
                      </block>
                    </statement>
                    <next>
                      <block type="controls_if" id="eo_sl_chk">
                        <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                        <value name="IF0">
                          <block type="logic_compare" id="eo_sl_cmp">
                            <field name="OP">LTE</field>
                            <value name="A"><block type="total_profit" id="eo_sl_tp"></block></value>
                            <value name="B">
                              <block type="math_single" id="eo_sl_neg">
                                <field name="OP">NEG</field>
                                <value name="NUM"><shadow type="math_number"><field name="NUM">5</field></shadow><block type="variables_get" id="eo_sl_g"><field name="VAR" id="eo_v_sl">Stop Loss</field></block></value>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="text_join" id="eo_sl_tj">
                            <field name="VARIABLE" id="eo_v_txt">text</field>
                            <statement name="STACK">
                              <block type="text_statement" id="eo_sl_ts1"><value name="TEXT"><shadow type="text"><field name="TEXT">🛑 Stop Loss hit! </field></shadow></value>
                                <next><block type="text_statement" id="eo_sl_ts2"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="total_profit" id="eo_sl_tp_v"></block></value>
                                  <next><block type="text_statement" id="eo_sl_ts3"><value name="TEXT"><shadow type="text"><field name="TEXT"> USD — bot stopped.</field></shadow></value></block></next>
                                </block></next>
                              </block>
                            </statement>
                            <next>
                              <block type="notify" id="eo_sl_n">
                                <field name="NOTIFICATION_TYPE">error</field>
                                <field name="NOTIFICATION_SOUND">error</field>
                                <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_sl_txt_g"><field name="VAR" id="eo_v_txt">text</field></block></value>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <statement name="ELSE">
                          <block type="controls_if" id="eo_ml_chk">
                            <mutation xmlns="http://www.w3.org/1999/xhtml" else="1"></mutation>
                            <value name="IF0">
                              <block type="logic_compare" id="eo_ml_cmp">
                                <field name="OP">LTE</field>
                                <value name="A"><block type="variables_get" id="eo_lc_g"><field name="VAR" id="eo_v_lc">Loss Counter</field></block></value>
                                <value name="B"><block type="variables_get" id="eo_ml_g"><field name="VAR" id="eo_v_ml">Max Losses</field></block></value>
                              </block>
                            </value>
                            <statement name="DO0"><block type="trade_again" id="eo_ta_loss"></block></statement>
                            <statement name="ELSE">
                              <block type="text_join" id="eo_ml_tj">
                                <field name="VARIABLE" id="eo_v_txt">text</field>
                                <statement name="STACK">
                                  <block type="text_statement" id="eo_ml_ts1"><value name="TEXT"><shadow type="text"><field name="TEXT">❌ Max losses hit! </field></shadow></value>
                                    <next><block type="text_statement" id="eo_ml_ts2"><value name="TEXT"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="total_profit" id="eo_ml_tp_v"></block></value>
                                      <next><block type="text_statement" id="eo_ml_ts3"><value name="TEXT"><shadow type="text"><field name="TEXT"> USD — bot stopped.</field></shadow></value></block></next>
                                    </block></next>
                                  </block>
                                </statement>
                                <next>
                                  <block type="notify" id="eo_ml_n">
                                    <field name="NOTIFICATION_TYPE">error</field>
                                    <field name="NOTIFICATION_SOUND">error</field>
                                    <value name="MESSAGE"><shadow type="text"><field name="TEXT">abc</field></shadow><block type="variables_get" id="eo_ml_txt_g"><field name="VAR" id="eo_v_txt">text</field></block></value>
                                  </block>
                                </next>
                              </block>
                            </statement>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
