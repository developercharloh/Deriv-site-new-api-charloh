  </block>

  <!-- ═══════════════════════════════════════════════════════
       TICK ANALYSIS — last digit + entry point on journal
       ═══════════════════════════════════════════════════════ -->
  <block type="tick_analysis" id="ouai_tick_analysis" x="0" y="1464">
    <statement name="TICKANALYSIS_STACK">
      <!-- Get last digit from tick list -->
      <block type="variables_set" id="ouai_tick1_set">
        <field name="VAR" id="ouai_var_tick1">Tick 1</field>
        <value name="VALUE">
          <block type="lists_getIndex" id="ouai_last_digit_get">
            <mutation xmlns="http://www.w3.org/1999/xhtml" statement="false" at="true"></mutation>
            <field name="MODE">GET</field>
            <field name="WHERE">FROM_END</field>
            <value name="VALUE">
              <block type="lastDigitList" id="ouai_digit_list"></block>
            </value>
            <value name="AT">
              <block type="math_number" id="ouai_digit_at"><field name="NUM">1</field></block>
            </value>
          </block>
        </value>
        <next>
          <!-- Log last digit and entry point to journal every tick -->
          <block type="text_join" id="ouai_tick_tj">
            <field name="VARIABLE" id="ouai_var_text">Text</field>
            <statement name="STACK">
              <block type="text_statement" id="ouai_tick_ts1">
                <value name="TEXT">
                  <shadow type="text"><field name="TEXT"></field></shadow>
                  <block type="text" id="ouai_tick_t1"><field name="TEXT">Last Digit: </field></block>
                </value>
                <next>
                  <block type="text_statement" id="ouai_tick_ts2">
                    <value name="TEXT">
                      <shadow type="text"><field name="TEXT"></field></shadow>
                      <block type="variables_get" id="ouai_tick1_log">
                        <field name="VAR" id="ouai_var_tick1">Tick 1</field>
                      </block>
                    </value>
                    <next>
                      <block type="text_statement" id="ouai_tick_ts3">
                        <value name="TEXT">
                          <shadow type="text"><field name="TEXT"></field></shadow>
                          <block type="text" id="ouai_tick_t3"><field name="TEXT">  |  Entry Point: </field></block>
                        </value>
                        <next>
                          <block type="text_statement" id="ouai_tick_ts4">
                            <value name="TEXT">
                              <shadow type="text"><field name="TEXT"></field></shadow>
                              <block type="variables_get" id="ouai_ep_log">
                                <field name="VAR" id="ouai_var_ep">Entry Point</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="notify" id="ouai_tick_print">
                <field name="NOTIFICATION_TYPE">info</field>
                <field name="NOTIFICATION_SOUND">silent</field>
                <value name="MESSAGE">
                  <shadow type="text"><field name="TEXT">abc</field></shadow>
                  <block type="variables_get" id="ouai_tick_print_get">
                    <field name="VAR" id="ouai_var_text">Text</field>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
