                    </next>
                  </block>
                </next>
              </block>
            </statement>

            <!-- ELSE recovery: buy recovery direction -->
            <statement name="ELSE">
              <block type="text_join" id="ouai_pred2_tj">
                <field name="VARIABLE" id="ouai_var_text">Text</field>
                <statement name="STACK">
                  <block type="text_statement" id="ouai_pred2_ts1">
                    <value name="TEXT">
                      <shadow type="text"><field name="TEXT"></field></shadow>
                      <block type="text" id="ouai_pred2_t1"><field name="TEXT">🔄 Prediction 2 (recovery) — Barrier: </field></block>
                    </value>
                    <next>
                      <block type="text_statement" id="ouai_pred2_ts2">
